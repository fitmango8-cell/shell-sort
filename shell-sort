import random      # бібліотека для генерації випадкових чисел
import time        # бібліотека для вимірювання часу

# функція сортування Шелла
def shell_sort(arr):
    n = len(arr)  # отримуємо довжину масиву
    gap = n // 2  # початковий крок (половина масиву)

    print("\nПочатковий масив:", arr)

    # цикл працює поки крок більше 0
    while gap > 0:
        print(f"\nПоточний крок (gap): {gap}")

        # проходимо по масиву
        for i in range(gap, n):
            temp = arr[i]  # зберігаємо поточний елемент
            j = i          # індекс для переміщення

            # сортування вставками з кроком gap
            while j >= gap and arr[j - gap] > temp:
                arr[j] = arr[j - gap]  # зміщуємо елемент вправо
                j -= gap               # переходимо назад на gap

            arr[j] = temp  # вставляємо елемент на правильну позицію

        print("Після проходу:", arr)

        gap //= 2  # зменшуємо крок у 2 рази

    return arr  # повертаємо відсортований масив


# функція введення масиву вручну
def manual_input():
    data = input("Введіть числа через пробіл: ")  # зчитуємо рядок
    arr = list(map(int, data.split()))  # перетворюємо рядок у список чисел
    return arr  # повертаємо масив


# функція генерації випадкового масиву
def random_array():
    size = int(input("Розмір масиву: "))      # вводимо розмір масиву
    min_val = int(input("Мін значення: "))    # мінімальне значення
    max_val = int(input("Макс значення: "))   # максимальне значення

    # створюємо масив випадкових чисел
    arr = [random.randint(min_val, max_val) for _ in range(size)]
    return arr  # повертаємо масив


# функція сортування з вимірюванням часу
def sort_with_timer(arr):
    start = time.time()  # початок вимірювання часу
    sorted_arr = shell_sort(arr.copy())  # сортуємо копію масиву
    end = time.time()  # кінець вимірювання часу

    print("\nВідсортований масив:", sorted_arr)
    print("Час сортування:", round(end - start, 6), "сек")  # виводимо час


# головна функція меню
def main():
    while True:
        print("\n===== Сортування Шелла =====")
        print("1 - Ввести масив вручну")
        print("2 - Згенерувати випадковий масив")
        print("3 - Вийти")

        choice = input("Оберіть варіант: ")  # зчитуємо вибір користувача

        if choice == "1":
            arr = manual_input()  # вводимо масив
            sort_with_timer(arr)  # сортуємо

        elif choice == "2":
            arr = random_array()  # генеруємо масив
            print("Згенерований масив:", arr)
            sort_with_timer(arr)  # сортуємо

        elif choice == "3":
            print("Вихід...")
            break  # вихід з програми

        else:
            print("Неправильний вибір!")  # повідомлення про помилку

# точка входу в програму
if __name__ == "__main__":
    main()  # запуск головної функції
